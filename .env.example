# Root deployment values
# Copy into server/.env for local/private server configuration.
AIRDRAW_API_TOKEN=
AIRDRAW_ALLOWED_ORIGINS=http://localhost:5173
AIRDRAW_DATA_DIR=./data

# Optional frontend build-time value.
# In a Vite deployment, set this as VITE_API_BASE_URL.
VITE_API_BASE_URL=http://127.0.0.1:8787
