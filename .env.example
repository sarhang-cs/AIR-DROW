# Required for the real server-side AI Studio on Vercel.
# Never place this key in client-side JavaScript or commit a real .env file.
OPENAI_API_KEY=
AIRDROW_AI_ENABLED=false
AIRDROW_AI_MODEL=gpt-image-2
AIRDROW_AI_QUALITY=low

# Optional: comma-separated deployed origins allowed to call /api/ai/generate.
# Example: https://your-project.vercel.app,https://your-domain.com
AIRDROW_AI_ALLOWED_ORIGINS=
